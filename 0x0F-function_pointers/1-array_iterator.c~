#include <stddef.h>
/**
* array_iterator - executes a function
* @array: array
* @size_t: - size
* @size: size
* @action: action
* Return: always 0
*/
void array_iterator(int *array, size_t size, void (*action)(int))
{
size_t i;
if (array != NULL && action != NULL)
{
for (i = 0; i < size; i++)
{
action(array[i]);
}
}
}
