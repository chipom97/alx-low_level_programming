#include "main.h"
#include <stdio.h>

/**
 * _strncpy - copy string
 * @dest: destination string
 * @src: source string
 * @n: integer
 * Return: string
 */

char *_strncpy(char *dest, char *src, int n)
{
int copy = 0;

while (src[copy] != '\0' && copy < n)
{
dest[copy] = src[copy];
copy++;
}
dest[copy] = '\0';
return (dest);
}
