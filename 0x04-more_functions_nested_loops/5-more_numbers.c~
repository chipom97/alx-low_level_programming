#include "main.h"
/**
* more_numbers - prints 10 sets of numbers
*
* Return: Always 0
*/
void more_numbers(void)
{
int i, num;

for (i = 0; i < 10; i++)
{
for (num = 0; num <= 14; num++)
{
if (num > 9)
{
_putchar('0' + num / 10); // Print the tens digit
}
_putchar('0' + num % 10); // Print the ones digit
}
_putchar('\n'); // Print a new line after each set of numbers
}
}
