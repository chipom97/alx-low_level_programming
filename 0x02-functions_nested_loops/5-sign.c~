#include "main.h"
/**
* print_sign - Prints the sign of a number
* @n: The number to check
* Return: 1 - positive
* Return: 0 - zero
* Return: -1 - negative
*/
int print_sign(int n)

{
	if (n > 0)
	{
		_putchar('+');
		return (1);
	}
	else if (n == 0)
	{
		_putchar('0');
		return (0);
	}
	else
	{
		_putchar('-');
		return (-1);
	}
}
